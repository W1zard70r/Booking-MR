# Database Configuration
DB_HOST=localhost
DB_PORT=5437
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=booking
DB_SSLMODE=disable

# Application Configuration
SERVER_PORT=8080
JWT_SECRET=supersecretkey_for_jwt

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

RABBITMQ_URL=
RABBITMQ_BOOKING_EVENTS_QUEUE=booking-events
RABBITMQ_BOOKING_STATUS_EVENTS_QUEUE=booking-status-events

# SMTP Notifications
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
